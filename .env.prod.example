COMPOSE_PROJECT_NAME=toniq-prod
APP_IMAGE_REPOSITORY=ghcr.io/OWNER/toniq-backend
APP_IMAGE_TAG=latest
FRONTEND_IMAGE_REPOSITORY=ghcr.io/OWNER/toniq-frontend
FRONTEND_IMAGE_TAG=latest
PUBLIC_DOMAIN=example.com
ADMIN_DOMAIN=admin.example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=toniq
POSTGRES_USER=toniq
POSTGRES_PASSWORD=change-me

POSTGRES_PORT=5432
APP_PORT=8080
FRONTEND_PORT=8081

MEGATIX_BASE_URL=https://api.megatix.example
MEGATIX_EMAIL=megatix@example.com
MEGATIX_PASSWORD=change-me
MEGATIX_WEBHOOK_SIGNATURE=change-me
MEGATIX_TOKEN_REFRESH_SKEW_SECONDS=30
PUBLIC_API_BASE_URL=/api/public

BACKEND_HEALTH_URL=http://127.0.0.1:8080/login
FRONTEND_HEALTH_URL=http://127.0.0.1:8081/
